{
  "name": "electron-forge-publisher-azure",
  "version": "0.1.2",
  "description": "Azure publisher for Electron Forge",
  "keywords": [
    "electron-forge",
    "publisher",
    "azure",
    "azure-blob-storage",
    "electron",
    "forge-publisher"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/XtN/electron-forge-publisher-azure"
  },
  "bugs": {
    "url": "https://github.com/XtN/electron-forge-publisher-azure/issues"
  },
  "homepage": "https://github.com/XtN/electron-forge-publisher-azure#readme",
  "author": "XtN",
  "license": "MIT",
  "main": "dist/PublisherAzure.js",
  "typings": "dist/PublisherAzure.d.ts",
  "exports": {
    ".": {
      "require": "./dist/PublisherAzure.js",
      "types": "./dist/PublisherAzure.d.ts"
    }
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "prettier": "^3.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@azure/storage-blob": "12.26.0",
    "@electron-forge/publisher-static": "^7",
    "@electron-forge/shared-types": "^7",
    "debug": "^4.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "pnpm run clean && tsc -p ./tsconfig.json",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "files": [
    "dist",
    "src"
  ],
  "packageManager": "pnpm@10.30.3"
}
